glIsSync:                          proc "c" (sync: sync_t) -> bool
glDeleteSync:                      proc "c" (sync: sync_t)
glClientWaitSync:                  proc "c" (sync: sync_t, flags: uint, timeout: u64) -> uint
glWaitSync:                        proc "c" (sync: sync_t, flags: uint, timeout: u64)
