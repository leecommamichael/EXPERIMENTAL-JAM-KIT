glGetBufferParameteri64v:          proc "c" (target: uint, pname: uint, params: [^]i64)
glFramebufferTexture:              proc "c" (target: uint, attachment: uint, texture: uint, level: int)
glTexImage2DMultisample:           proc "c" (target: uint, samples: int, internalformat: uint, width: int, height: int, fixedsamplelocations: bool)
glTexImage3DMultisample:           proc "c" (target: uint, samples: int, internalformat: uint, width: int, height: int, depth: int, fixedsamplelocations: bool)
glGetMultisamplefv:                proc "c" (pname: uint, index: uint, val: ^GLfloat)
